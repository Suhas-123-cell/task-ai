# Copy this file to backend/.env and fill in real values.

# --- LLM (Groq) ---
# Get a free key at https://console.groq.com
# If left blank, the system still runs end-to-end using deterministic
# fallback question generation / answer scoring (lower quality, but functional).
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- CORS: comma-separated list of allowed frontend origins ---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Interview length ---
MAX_INTERVIEW_QUESTIONS=5

# --- Retrieval tuning (defaults are usually fine) ---
RETRIEVAL_TOP_K=4
# Below this cosine similarity, a retrieved chunk is dropped rather than padding
# the LLM prompt with low-relevance content (context-rot mitigation).
RETRIEVAL_MIN_SIMILARITY=0.15

# --- Semantic chunking tuning (defaults are usually fine) ---
# Lower threshold = fewer, larger chunks (less sensitive to topic shifts).
# Higher threshold = more, smaller chunks (splits more eagerly).
SEMANTIC_SIMILARITY_THRESHOLD=0.55
MIN_CHUNK_CHARS=300
MAX_CHUNK_CHARS=1400
